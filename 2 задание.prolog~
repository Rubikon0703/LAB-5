% Программа: подсчет минимальных элементов

find_min([X], X).
find_min([H|T], Min) :-
    find_min(T, MinTail),
    H < MinTail,
    Min = H.
find_min([H|T], Min) :-
    find_min(T, Min),
    H >= Min.

count([], _, 0).
count([H|T], X, N) :-
    H = X,
    count(T, X, N1),
    N is N1 + 1.
count([H|T], X, N) :-
    H \= X,
    count(T, X, N).

